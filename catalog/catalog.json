{
  "schemaVersion": 1,
  "scripts": [
    {
      "id": "pdf-to-obsidian-images",
      "name": "PDF to Obsidian images",
      "version": "1.3.3",
      "description": "Render a PDF into per-page JPG images, create a Markdown note, and store extracted page text in hidden HTML alt attributes.",
      "fileName": "pdf_to_obsidian_images.py",
      "path": "pdf_to_obsidian_images.py",
      "preset": {
        "id": "pdf-to-obsidian-images",
        "name": "PDF to Obsidian images",
        "command": "{{venvPython}}",
        "arguments": "{{scriptPath}}\n--vault\n{{vault}}\n--attachments\n_Attachments\n--attachment-subdir\n{pdf_stem}\n--output\n{{activeFolderPrefix}}{{pdfPath.stem}}.md\n--title\n{{pdfPath.stem}}\n--backend\nauto\n--link-style\nhtml\n--alt-text\nextracted\n--text-output\nnone\n--format\njpg\n{{pdfPath}}",
        "cwd": "{{vault}}",
        "parameters": [
          {
            "name": "pdfPath",
            "label": "PDF path",
            "placeholder": "C:\\Users\\you\\Downloads\\lecture.pdf",
            "defaultValue": "{{latestDownloadPdf}}"
          }
        ],
        "env": "",
        "useVenv": true,
        "venvPath": "",
        "pythonExecutable": "",
        "requirements": "pymupdf",
        "runInShell": false,
        "openOutput": true
      }
    },
    {
      "id": "clean-chatgpt-research",
      "name": "Clean ChatGPT research report",
      "version": "0.1.0",
      "description": "Fix a ChatGPT deep-research Markdown report for Obsidian: convert \\( \\) and \\[ \\] math to $ and $$, and strip invisible citation artifacts.",
      "fileName": "clean_gpt_research.py",
      "path": "clean_gpt_research.py",
      "preset": {
        "id": "clean-chatgpt-research",
        "name": "Clean ChatGPT research report",
        "command": "{{venvPython}}",
        "arguments": "{{scriptPath}}\n--vault\n{{vault}}\n--in-place\n{{mdPath}}",
        "cwd": "{{vault}}",
        "parameters": [
          {
            "name": "mdPath",
            "label": "Report path",
            "placeholder": "Folder/Report.md",
            "defaultValue": "{{activeFile}}"
          }
        ],
        "env": "",
        "useVenv": true,
        "venvPath": "",
        "pythonExecutable": "",
        "requirements": "",
        "runInShell": false,
        "openOutput": true
      }
    }
  ]
}
